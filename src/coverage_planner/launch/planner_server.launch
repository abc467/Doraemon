<launch>
  <arg name="plan_db_path" default="/data/coverage/planning.db"/>
  <arg name="ops_db_path" default="/data/coverage/operations.db"/>
  <arg name="maps_root" default="/data/maps"/>
  <arg name="planner_defaults_yaml" default="$(find coverage_planner)/config/planner_server_defaults.yaml"/>
  <arg name="robot_id" default="local_robot"/>
  <arg name="map_topic" default="/map"/>
  <arg name="tracked_pose_topic" default="/tracked_pose"/>
  <arg name="runtime_ns" default="/cartographer/runtime"/>
  <arg name="enable_rect_zone_planner" default="true"/>
  <arg name="enable_slam_runtime_manager" default="true"/>
  <arg name="enable_slam_api_service" default="true"/>
  <arg name="enable_odometry_health" default="false"/>
  <arg name="odometry_health_imu_topic" default="/imu_corrected"/>
  <arg name="odometry_health_ekf_node_name" default="/wheel_speed_odom_ekf"/>
  <arg name="clicked_topic" default="/clicked_point"/>
  <arg name="selection_inset_m" default="0.05"/>
  <arg name="hole_outset_m" default="0.05"/>
  <arg name="min_effective_side_m" default="0.10"/>
  <arg name="default_plan_profile_name" default="cover_standard"/>
  <arg name="rect_plan_action_name" default="/coverage_planner_server/plan_coverage"/>
  <arg name="rect_plan_timeout_s" default="120.0"/>
  <arg name="enable_site_editor_service" default="true"/>
  <arg name="default_aligned_frame" default="site_map"/>
  <arg name="rect_min_side_m" default="0.10"/>
  <arg name="preview_nominal_speed_mps" default="0.35"/>
  <arg name="default_sys_profile_name" default="standard"/>
  <arg name="alignment_app_service_name" default="/database_server/app/map_alignment_service"/>
  <arg name="alignment_site_service_name" default="/database_server/site/map_alignment_service"/>
  <arg name="alignment_points_app_service_name" default="/database_server/app/map_alignment_by_points_service"/>
  <arg name="alignment_points_site_service_name" default="/database_server/site/map_alignment_by_points_service"/>
  <arg name="rect_preview_app_service_name" default="/database_server/app/rect_zone_preview_service"/>
  <arg name="rect_preview_site_service_name" default="/database_server/site/rect_zone_preview_service"/>
  <arg name="plan_preview_app_service_name" default="/database_server/app/coverage_preview_service"/>
  <arg name="plan_preview_site_service_name" default="/database_server/site/coverage_preview_service"/>
  <arg name="plan_commit_app_service_name" default="/database_server/app/coverage_commit_service"/>
  <arg name="plan_commit_site_service_name" default="/database_server/site/coverage_commit_service"/>
  <arg name="zone_query_app_service_name" default="/database_server/app/coverage_zone_service"/>
  <arg name="zone_query_site_service_name" default="/database_server/site/coverage_zone_service"/>
  <arg name="zone_plan_path_app_service_name" default="/database_server/app/zone_plan_path_service"/>
  <arg name="zone_plan_path_site_service_name" default="/database_server/site/zone_plan_path_service"/>
  <arg name="no_go_area_app_service_name" default="/database_server/app/no_go_area_service"/>
  <arg name="no_go_area_site_service_name" default="/database_server/site/no_go_area_service"/>
  <arg name="virtual_wall_app_service_name" default="/database_server/app/virtual_wall_service"/>
  <arg name="virtual_wall_site_service_name" default="/database_server/site/virtual_wall_service"/>
  <arg name="profile_catalog_app_service_name" default="/database_server/app/profile_catalog_service"/>
  <arg name="slam_state_topic_name" default="/clean_robot_server/slam_state"/>
  <arg name="slam_job_state_topic_name" default="/clean_robot_server/slam_job_state"/>
  <arg name="odometry_state_topic_name" default="/clean_robot_server/odometry_state"/>
  <arg name="task_state_topic_name" default="/task_state"/>
  <arg name="slam_status_app_service_name" default="/clean_robot_server/app/get_slam_status"/>
  <arg name="odometry_status_app_service_name" default="/clean_robot_server/app/get_odometry_status"/>
  <arg name="slam_submit_command_app_service_name" default="/clean_robot_server/app/submit_slam_command"/>
  <arg name="slam_get_job_app_service_name" default="/clean_robot_server/app/get_slam_job"/>
  <arg name="slam_runtime_manager_app_service_name" default="/cartographer/runtime/app/operate"/>
  <arg name="slam_runtime_submit_job_app_service_name" default="/cartographer/runtime/app/submit_job"/>
  <arg name="slam_runtime_get_job_app_service_name" default="/cartographer/runtime/app/get_job"/>
  <arg name="slam_runtime_job_state_topic_name" default="/cartographer/runtime/job_state"/>
  <arg name="profile_catalog_app_contract_param_ns" default="/database_server/contracts/app/profile_catalog_service"/>
  <arg name="slam_status_app_contract_param_ns" default="/clean_robot_server/contracts/app/get_slam_status"/>
  <arg name="odometry_status_app_contract_param_ns" default="/clean_robot_server/contracts/app/get_odometry_status"/>
  <arg name="slam_submit_command_app_contract_param_ns" default="/clean_robot_server/contracts/app/submit_slam_command"/>
  <arg name="slam_get_job_app_contract_param_ns" default="/clean_robot_server/contracts/app/get_slam_job"/>
  <arg name="slam_runtime_manager_app_contract_param_ns" default="/cartographer/runtime/contracts/app/operate"/>
  <arg name="slam_runtime_submit_job_app_contract_param_ns" default="/cartographer/runtime/contracts/app/submit_job"/>
  <arg name="slam_runtime_get_job_app_contract_param_ns" default="/cartographer/runtime/contracts/app/get_job"/>

  <node pkg="coverage_planner" type="planner_server_node.py" name="coverage_planner_server" output="screen" respawn="true" respawn_delay="2.0">
    <rosparam command="load" file="$(arg planner_defaults_yaml)"/>
    <param name="plan_db_path" value="$(arg plan_db_path)"/>
    <param name="robot_id" value="$(arg robot_id)"/>
    <param name="map_topic" value="$(arg map_topic)"/>
  </node>

  <group if="$(arg enable_rect_zone_planner)">
    <node pkg="coverage_planner" type="rect_zone_planner_node.py" name="rect_zone_planner" output="screen" respawn="true" respawn_delay="2.0">
      <param name="plan_db_path" value="$(arg plan_db_path)"/>
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="map_topic" value="$(arg map_topic)"/>
      <param name="clicked_topic" value="$(arg clicked_topic)"/>
      <param name="selection_inset_m" value="$(arg selection_inset_m)"/>
      <param name="hole_outset_m" value="$(arg hole_outset_m)"/>
      <param name="min_effective_side_m" value="$(arg min_effective_side_m)"/>
      <param name="default_plan_profile_name" value="$(arg default_plan_profile_name)"/>
      <param name="plan_action_name" value="$(arg rect_plan_action_name)"/>
      <param name="plan_timeout_s" value="$(arg rect_plan_timeout_s)"/>
    </node>
  </group>

  <group if="$(arg enable_site_editor_service)">
    <node pkg="coverage_planner" type="site_editor_service_node.py" name="site_editor_service" output="screen" respawn="true" respawn_delay="2.0">
      <rosparam command="load" file="$(arg planner_defaults_yaml)"/>
      <param name="plan_db_path" value="$(arg plan_db_path)"/>
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="default_aligned_frame" value="$(arg default_aligned_frame)"/>
      <param name="rect_min_side_m" value="$(arg rect_min_side_m)"/>
      <param name="preview_nominal_speed_mps" value="$(arg preview_nominal_speed_mps)"/>
      <param name="default_plan_profile_name" value="$(arg default_plan_profile_name)"/>
      <param name="app_alignment_service_name" value="$(arg alignment_app_service_name)"/>
      <param name="site_alignment_service_name" value="$(arg alignment_site_service_name)"/>
      <param name="app_alignment_points_service_name" value="$(arg alignment_points_app_service_name)"/>
      <param name="site_alignment_points_service_name" value="$(arg alignment_points_site_service_name)"/>
      <param name="app_rect_preview_service_name" value="$(arg rect_preview_app_service_name)"/>
      <param name="site_rect_preview_service_name" value="$(arg rect_preview_site_service_name)"/>
      <param name="app_plan_preview_service_name" value="$(arg plan_preview_app_service_name)"/>
      <param name="site_plan_preview_service_name" value="$(arg plan_preview_site_service_name)"/>
      <param name="app_plan_commit_service_name" value="$(arg plan_commit_app_service_name)"/>
      <param name="site_plan_commit_service_name" value="$(arg plan_commit_site_service_name)"/>
      <param name="app_zone_query_service_name" value="$(arg zone_query_app_service_name)"/>
      <param name="site_zone_query_service_name" value="$(arg zone_query_site_service_name)"/>
      <param name="app_zone_plan_path_service_name" value="$(arg zone_plan_path_app_service_name)"/>
      <param name="site_zone_plan_path_service_name" value="$(arg zone_plan_path_site_service_name)"/>
      <param name="app_no_go_area_service_name" value="$(arg no_go_area_app_service_name)"/>
      <param name="site_no_go_area_service_name" value="$(arg no_go_area_site_service_name)"/>
      <param name="app_virtual_wall_service_name" value="$(arg virtual_wall_app_service_name)"/>
      <param name="site_virtual_wall_service_name" value="$(arg virtual_wall_site_service_name)"/>
    </node>
  </group>

  <group if="$(arg enable_odometry_health)">
    <node pkg="coverage_planner" type="odometry_health_node.py" name="odometry_health" output="screen" respawn="true" respawn_delay="2.0">
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="validation_mode" value="odom_stream"/>
      <param name="require_odom_frame_ids" value="true"/>
      <param name="emit_auxiliary_diagnostics" value="false"/>
      <param name="raw_odom_topic" value="/odom_raw"/>
      <param name="odom_topic" value="/odom"/>
      <param name="imu_topic" value="$(arg odometry_health_imu_topic)"/>
      <param name="ekf_node_name" value="$(arg odometry_health_ekf_node_name)"/>
      <param name="state_topic_name" value="$(arg odometry_state_topic_name)"/>
      <param name="app_service_name" value="$(arg odometry_status_app_service_name)"/>
      <param name="app_contract_param_ns" value="$(arg odometry_status_app_contract_param_ns)"/>
    </node>
  </group>

  <node pkg="coverage_planner" type="profile_catalog_service_node.py" name="profile_catalog_service" output="screen" respawn="true" respawn_delay="2.0">
    <param name="plan_db_path" value="$(arg plan_db_path)"/>
    <param name="ops_db_path" value="$(arg ops_db_path)"/>
    <param name="app_service_name" value="$(arg profile_catalog_app_service_name)"/>
    <param name="app_contract_param_ns" value="$(arg profile_catalog_app_contract_param_ns)"/>
    <param name="default_plan_profile_name" value="$(arg default_plan_profile_name)"/>
    <param name="default_sys_profile_name" value="$(arg default_sys_profile_name)"/>
  </node>

  <group if="$(arg enable_slam_runtime_manager)">
    <node pkg="coverage_planner" type="slam_runtime_manager_node.py" name="slam_runtime_manager" output="screen" respawn="true" respawn_delay="2.0">
      <param name="plan_db_path" value="$(arg plan_db_path)"/>
      <param name="ops_db_path" value="$(arg ops_db_path)"/>
      <param name="maps_root" value="$(arg maps_root)"/>
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="runtime_ns" value="$(arg runtime_ns)"/>
      <param name="app_service_name" value="$(arg slam_runtime_manager_app_service_name)"/>
      <param name="app_submit_job_service_name" value="$(arg slam_runtime_submit_job_app_service_name)"/>
      <param name="app_get_job_service_name" value="$(arg slam_runtime_get_job_app_service_name)"/>
      <param name="job_state_topic_name" value="$(arg slam_runtime_job_state_topic_name)"/>
      <param name="app_service_contract_param_ns" value="$(arg slam_runtime_manager_app_contract_param_ns)"/>
      <param name="app_submit_job_contract_param_ns" value="$(arg slam_runtime_submit_job_app_contract_param_ns)"/>
      <param name="app_get_job_contract_param_ns" value="$(arg slam_runtime_get_job_app_contract_param_ns)"/>
      <param name="map_topic" value="$(arg map_topic)"/>
      <param name="tracked_pose_topic" value="$(arg tracked_pose_topic)"/>
      <param name="odom_topic" value="/odom"/>
      <param name="odometry_status_service" value="$(arg odometry_status_app_service_name)"/>
    </node>
  </group>

  <group if="$(arg enable_slam_api_service)">
    <node pkg="coverage_planner" type="slam_api_service_node.py" name="slam_api_service" output="screen" respawn="true" respawn_delay="2.0">
      <param name="plan_db_path" value="$(arg plan_db_path)"/>
      <param name="ops_db_path" value="$(arg ops_db_path)"/>
      <param name="maps_root" value="$(arg maps_root)"/>
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="runtime_ns" value="$(arg runtime_ns)"/>
      <param name="map_topic" value="$(arg map_topic)"/>
      <param name="tracked_pose_topic" value="$(arg tracked_pose_topic)"/>
      <param name="task_state_topic" value="$(arg task_state_topic_name)"/>
      <param name="state_topic_name" value="$(arg slam_state_topic_name)"/>
      <param name="job_state_topic_name" value="$(arg slam_job_state_topic_name)"/>
      <param name="odometry_state_topic_name" value="$(arg odometry_state_topic_name)"/>
      <param name="odometry_status_service_name" value="$(arg odometry_status_app_service_name)"/>
      <param name="app_status_service_name" value="$(arg slam_status_app_service_name)"/>
      <param name="app_submit_command_service_name" value="$(arg slam_submit_command_app_service_name)"/>
      <param name="app_get_job_service_name" value="$(arg slam_get_job_app_service_name)"/>
      <param name="app_runtime_submit_job_service" value="$(arg slam_runtime_submit_job_app_service_name)"/>
      <param name="app_runtime_get_job_service" value="$(arg slam_runtime_get_job_app_service_name)"/>
      <param name="runtime_job_state_topic" value="$(arg slam_runtime_job_state_topic_name)"/>
      <param name="app_status_contract_param_ns" value="$(arg slam_status_app_contract_param_ns)"/>
      <param name="app_submit_command_contract_param_ns" value="$(arg slam_submit_command_app_contract_param_ns)"/>
      <param name="app_get_job_contract_param_ns" value="$(arg slam_get_job_app_contract_param_ns)"/>
    </node>
  </group>
</launch>
