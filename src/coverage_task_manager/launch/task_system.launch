<launch>
  <!--
    Task+Execute quick bringup:
      - Executor executes stored plans (DB) and keeps dev cmd topic.
      - Task manager monitors battery and orchestrates auto-charge.

    用法（默认推荐：Task 层负责回充，Executor 关闭回充）：
      roslaunch coverage_task_manager task_system.launch

    若你要单独验证 Executor 的 AutoChargeManager（不建议在系统模式长期这样开）：
      roslaunch coverage_task_manager task_system.launch task_auto_charge_enable:=false executor_auto_charge_enable:=true
  -->

  <arg name="task_auto_charge_enable" default="false"/>
  <arg name="executor_auto_charge_enable" default="false"/>
  <arg name="default_return_to_dock_on_finish" default="true"/>
  <arg name="scheduler_enable" default="true"/>
  <arg name="load_schedules_yaml" default="false"/>
  <arg name="schedules_yaml" default="$(find coverage_task_manager)/config/schedules_monday_0810.yaml"/>
  <arg name="scheduler_window_s" default="60.0"/>
  <arg name="scheduler_check_hz" default="1.0"/>
  <arg name="scheduler_catch_up_s" default="600.0"/>
  <arg name="scheduler_retry_backoff_s" default="30.0"/>
  <arg name="scheduler_reload_enable" default="true"/>
  <arg name="scheduler_reload_period_s" default="5.0"/>
  <arg name="load_mode_profiles_yaml" default="true"/>
  <arg name="load_actuator_profiles_yaml" default="true"/>
  <arg name="dock_supply_enable" default="true"/>
  <arg name="dock_supply_set_defer_exit_service" default="/dock_supply/set_defer_exit"/>
  <arg name="dock_supply_exit_service" default="/dock_supply/exit"/>
  <arg name="restart_localization_service" default="/cartographer/runtime/restart_localization"/>
  <arg name="start_localization_lifecycle_manager" default="true"/>
  <arg name="restart_localization_contract_param_ns" default="/cartographer/runtime/contracts/restart_localization"/>
  <arg name="cartographer_runtime_ns" default="/cartographer/runtime"/>
  <arg name="runtime_map_topic" default="/map"/>
  <arg name="tracked_pose_topic" default="/tracked_pose"/>
  <arg name="restart_localization_timeout_s" default="180.0"/>
  <arg name="clear_costmaps_service" default="/move_base_flex/clear_costmaps"/>
  <arg name="low_soc" default="0.80"/>
  <arg name="resume_soc" default="0.99"/>
  <arg name="rearm_soc" default="0.95"/>
  <arg name="plan_db_path" default="/data/coverage/planning.db"/>
  <arg name="ops_db_path" default="/data/coverage/operations.db"/>
  <arg name="maps_root" default="/data/maps"/>
  <arg name="robot_id" default="local_robot"/>
  <!-- legacy only: formal product flow does not auto-activate maps from task_system -->
  <arg name="activate_map_service" default="/map_assets/activate"/>
  <arg name="activate_map_timeout_s" default="10.0"/>
  <arg name="require_managed_map_asset" default="true"/>
  <arg name="require_runtime_localized_before_start" default="false"/>
  <arg name="require_runtime_map_match" default="false"/>
  <arg name="task_restore_enable" default="false"/>
  <arg name="allow_map_activation" default="false"/>
  <arg name="allow_legacy_zone_start" default="false"/>
  <arg name="run_map_migration" default="false"/>
  <arg name="legacy_map_src_glob" default=""/>

  <group if="$(arg run_map_migration)">
    <node pkg="coverage_planner" type="migrate_map_assets.py" name="map_asset_migration" output="screen"
          args="--plan-db-path $(arg plan_db_path) --ops-db-path $(arg ops_db_path) --maps-root $(arg maps_root) --src-glob $(arg legacy_map_src_glob) --robot-id $(arg robot_id) --set-active-if-missing"/>
  </group>

  <node if="$(arg start_localization_lifecycle_manager)"
        pkg="coverage_planner"
        type="localization_lifecycle_manager_node.py"
        name="localization_lifecycle_manager"
        output="screen">
    <param name="plan_db_path" value="$(arg plan_db_path)"/>
    <param name="ops_db_path" value="$(arg ops_db_path)"/>
    <param name="robot_id" value="$(arg robot_id)"/>
    <param name="runtime_ns" value="$(arg cartographer_runtime_ns)"/>
    <param name="service_name" value="$(arg restart_localization_service)"/>
    <param name="contract_param_ns" value="$(arg restart_localization_contract_param_ns)"/>
    <param name="map_topic" value="$(arg runtime_map_topic)"/>
    <param name="tracked_pose_topic" value="$(arg tracked_pose_topic)"/>
  </node>

  <include file="$(find coverage_executor)/launch/executor.launch">
    <arg name="auto_charge_enable" value="$(arg executor_auto_charge_enable)"/>
    <arg name="load_mode_profiles_yaml" value="$(arg load_mode_profiles_yaml)"/>
    <arg name="load_actuator_profiles_yaml" value="$(arg load_actuator_profiles_yaml)"/>
    <arg name="plan_db_path" value="$(arg plan_db_path)"/>
    <arg name="ops_db_path" value="$(arg ops_db_path)"/>
    <arg name="strict_map_check" value="false"/>
    <arg name="strict_resume_map_check" value="false"/>
  </include>

  <include file="$(find coverage_task_manager)/launch/task_manager.launch">
    <arg name="auto_charge_enable" value="$(arg task_auto_charge_enable)"/>
    <arg name="default_return_to_dock_on_finish" value="$(arg default_return_to_dock_on_finish)"/>
    <arg name="dock_supply_enable" value="$(arg dock_supply_enable)"/>
    <arg name="dock_supply_set_defer_exit_service" value="$(arg dock_supply_set_defer_exit_service)"/>
    <arg name="dock_supply_exit_service" value="$(arg dock_supply_exit_service)"/>
    <arg name="scheduler_enable" value="$(arg scheduler_enable)"/>
    <arg name="load_schedules_yaml" value="$(arg load_schedules_yaml)"/>
    <arg name="schedules_yaml" value="$(arg schedules_yaml)"/>
    <arg name="scheduler_window_s" value="$(arg scheduler_window_s)"/>
    <arg name="scheduler_check_hz" value="$(arg scheduler_check_hz)"/>
    <arg name="scheduler_catch_up_s" value="$(arg scheduler_catch_up_s)"/>
    <arg name="scheduler_retry_backoff_s" value="$(arg scheduler_retry_backoff_s)"/>
    <arg name="scheduler_reload_enable" value="$(arg scheduler_reload_enable)"/>
    <arg name="scheduler_reload_period_s" value="$(arg scheduler_reload_period_s)"/>
    <arg name="load_mode_profiles_yaml" value="$(arg load_mode_profiles_yaml)"/>
    <arg name="plan_db_path" value="$(arg plan_db_path)"/>
    <arg name="ops_db_path" value="$(arg ops_db_path)"/>
    <arg name="robot_id" value="$(arg robot_id)"/>
    <arg name="low_soc" value="$(arg low_soc)"/>
    <arg name="resume_soc" value="$(arg resume_soc)"/>
    <arg name="rearm_soc" value="$(arg rearm_soc)"/>
    <arg name="restart_localization_service" value="$(arg restart_localization_service)"/>
    <arg name="restart_localization_timeout_s" value="$(arg restart_localization_timeout_s)"/>
    <arg name="clear_costmaps_service" value="$(arg clear_costmaps_service)"/>
    <arg name="activate_map_service" value="$(arg activate_map_service)"/>
    <arg name="activate_map_timeout_s" value="$(arg activate_map_timeout_s)"/>
    <arg name="require_managed_map_asset" value="$(arg require_managed_map_asset)"/>
    <arg name="require_runtime_localized_before_start" value="$(arg require_runtime_localized_before_start)"/>
    <arg name="require_runtime_map_match" value="$(arg require_runtime_map_match)"/>
    <arg name="task_restore_enable" value="$(arg task_restore_enable)"/>
    <arg name="allow_map_activation" value="$(arg allow_map_activation)"/>
    <arg name="allow_legacy_zone_start" value="$(arg allow_legacy_zone_start)"/>
  </include>
</launch>
