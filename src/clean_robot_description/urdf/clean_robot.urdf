<?xml version="1.0"?>
<robot name="clean_robot">

  <!-- ===================== Frames ===================== -->
  <!-- Root at ground projection (no inertia/collision) -->
  <link name="base_footprint"/>

  <!-- Base link at wheel axle height -->
  <joint name="base_footprint_to_base_link" type="fixed">
    <!-- wheel radius = 0.09m (since wheel diameter 0.18m) -->
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- ===================== base_link ===================== -->
  <link name="base_link">
    <!-- Reasonable inertial (approx) -->
    <inertial>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <mass value="30.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="2.0" iyz="0" izz="3.0"/>
    </inertial>

    <!-- Visual: simple chassis box -->
    <visual name="base_visual">
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <!-- length x width x height (m) -->
        <box size="1.20 0.90 0.24"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>

    <!-- Collision: same as visual (keeps robot from falling through) -->
    <collision name="base_collision">
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="1.20 0.90 0.24"/>
      </geometry>
    </collision>
  </link>

  <!-- ===================== Wheels ===================== -->
  <!-- Parameters (hard-coded): -->
  <!-- wheel radius 0.09m (diameter 0.18m) -->
  <!-- wheel separation default 0.7105m (can tune if needed) -->

  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>

    <!-- Cylinder axis is Z by default, rotate so axis aligns with Y -->
    <visual name="left_wheel_visual">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>

    <collision name="left_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <!-- wheel center relative to base_link (at axle height) -->
    <origin xyz="0 0.35525 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="50"/>
  </joint>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>

    <visual name="right_wheel_visual">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision name="right_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.09" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="0 -0.35525 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" velocity="50"/>
  </joint>
 
   <!-- ===================== Casters (front & rear) ===================== -->
  <!-- base_link 在轮轴高度；地面在 base_link 的 z = -0.09 -->
  <!-- 万向轮用球：半径 0.03m，球心放在 z=-0.06，使其刚好接地 -->

  <link name="front_caster_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual name="front_caster_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
      <material name="darkgray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision name="front_caster_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <!-- 底盘长 1.2m，前缘约 x=+0.6；这里放在 x=+0.55，居中 y=0 -->
    <origin xyz="0.55 0.0 -0.043" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_caster_link"/>
  </joint>

  <link name="rear_caster_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual name="rear_caster_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
      <material name="darkgray"/>
    </visual>
    <collision name="rear_caster_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <!-- 后缘约 x=-0.6；这里放在 x=-0.55 -->
    <origin xyz="-0.55 0.0 -0.043" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_caster_link"/>
  </joint>



  <!-- ===================== Laser link (only this one publishes /scan) ===================== -->
  <link name="laser_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>

    <visual name="laser_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.06"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1.0"/>
      </material>
    </visual>

    <collision name="laser_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <!-- mount point: front-top of chassis -->
    <origin xyz="0.60 0 0.35" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="laser_link"/>
  </joint>
  <!-- ===================== IMU ===================== -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- IMU 位置：激光正下方 0.15m -->
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <parent link="laser_link"/>
    <child link="imu_link"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <updateRateHZ>100</updateRateHZ>
      <visualize>false</visualize>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <robotNamespace>/</robotNamespace>
          <topicName>imu/data</topicName>
          <frameName>imu_link</frameName>
          <updateRateHZ>100</updateRateHZ>
          <gaussianNoise>0.01</gaussianNoise>
      </plugin>

    </sensor>
  </gazebo>




  <!-- =========================================================
       Gazebo: wheel friction + diff drive + 2D lidar
       ========================================================= -->

  <!-- Wheel friction to help traction -->
  <gazebo reference="left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <gazebo reference="front_caster_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <gazebo reference="rear_caster_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>


  <!-- DiffDrive: /cmd_vel -> wheels, publish /odom and TF -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>

      <!-- Default wheel separation = 0.7105m (tune if your real robot differs) -->
      <wheelSeparation>0.7105</wheelSeparation>

      <!-- Wheel diameter per your input -->
      <wheelDiameter>0.18</wheelDiameter>

      <wheelTorque>50</wheelTorque>
      <updateRate>20</updateRate>

      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>

      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>

      <publishTf>true</publishTf>
      <publishWheelTF>false</publishWheelTF>

      <!-- publish joint_states so robot_state_publisher works -->
      <publishWheelJointState>true</publishWheelJointState>
      <jointStateTopic>joint_states</jointStateTopic>
    </plugin>
  </gazebo>

  <!-- 2D lidar on laser_link: /scan
       360deg, 720 points (0.5 deg), 10Hz, range 0.1~20m -->
<gazebo reference="laser_link">
  <sensor name="laser" type="ray">
    <pose>0 0 0 0 0 0</pose>
    <always_on>true</always_on>
    <update_rate>10</update_rate>
    <visualize>false</visualize>

    <ray>
      <scan>
        <horizontal>
          <samples>720</samples>
          <resolution>1</resolution>
          <min_angle>-3.1415926</min_angle>
          <max_angle>3.1415926</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.10</min>
        <max>20.0</max>
        <resolution>0.01</resolution>
      </range>

      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </ray>

    <!-- gazebo_ros_laser.so 的正确参数 -->
    <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
      <robotNamespace>/</robotNamespace>
      <topicName>scan</topicName>
      <frameName>laser_link</frameName>
    </plugin>
  </sensor>
</gazebo>

</robot>
