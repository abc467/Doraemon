<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="plan_db_path" default="/data/coverage/planning.db"/>
  <arg name="ops_db_path" default="/data/coverage/operations.db"/>
  <arg name="maps_root" default="/data/maps"/>
  <arg name="robot_id" default="local_robot"/>
  <arg name="map_name" default=""/>
  <arg name="map_version" default=""/>
  <arg name="start_task_api_service" default="true"/>

  <include file="$(find clean_robot_description)/launch/mbf_nav.launch">
    <arg name="plan_db_path" value="$(arg plan_db_path)"/>
    <arg name="ops_db_path" value="$(arg ops_db_path)"/>
    <arg name="robot_id" value="$(arg robot_id)"/>
    <arg name="map_name" value="$(arg map_name)"/>
    <arg name="map_version" value="$(arg map_version)"/>
  </include>

  <include file="$(find cleanrobot)/launch/amcl_diff.launch">
    <arg name="use_map_topic" value="true"/>
  </include>

  <node pkg="coverage_planner" type="map_asset_manager_node.py" name="map_asset_manager" output="screen">
    <param name="plan_db_path" value="$(arg plan_db_path)"/>
    <param name="maps_root" value="$(arg maps_root)"/>
    <param name="robot_id" value="$(arg robot_id)"/>
    <param name="map_topic" value="/map"/>
    <param name="set_active_on_save" value="true"/>
  </node>

  <group if="$(arg start_task_api_service)">
    <node pkg="coverage_task_manager" type="task_api_service_node.py" name="task_api_service" output="screen">
      <param name="plan_db_path" value="$(arg plan_db_path)"/>
      <param name="ops_db_path" value="$(arg ops_db_path)"/>
      <param name="robot_id" value="$(arg robot_id)"/>
      <param name="service_name" value="/database_server/clean_task_service"/>
    </node>
  </group>

  <include file="$(find ground_segmentation_tracking)/launch/duoxiangji.launch"/>
  <include file="$(find my_docking_controller)/launch/my_docking_controller.launch"/>
  <node pkg="dock_tracker" type="dock_tracker_node" name="dock_tracker_node"/>

  <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch"/>
</launch>
