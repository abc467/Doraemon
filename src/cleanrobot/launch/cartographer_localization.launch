<launch>
  <!-- Source-workspace legacy manual entry only.
       Excluded from formal install artifacts.
       Formal bringup now uses coverage_planner/planner_server.launch ->
       slam_runtime_manager as the runtime owner. -->
  <arg name="config_root" default=""/>
  <arg name="landmark_param_yaml" default=""/>
  <arg name="runtime_ns" default="/cartographer/runtime"/>
  <arg name="map_topic" default="/map"/>
  <arg name="resolution" default="0.05"/>
  <arg name="publish_period_sec" default="1.0"/>
  <arg name="map_name" default=""/>
  <arg name="pbstream_path" default=""/>
  <arg name="auto_start" default="false"/>
  <arg name="start_runtime_flag_bus" default="true"/>
  <arg name="cartographer_node_bin" default=""/>
  <arg name="occupancy_grid_node_bin" default=""/>

  <node if="$(arg start_runtime_flag_bus)"
        pkg="robot_runtime_flags"
        type="runtime_flag_server_node"
        name="runtime_flag_server"
        output="screen"
        respawn="true"
        respawn_delay="2.0"/>

  <node pkg="cleanrobot" type="cartographer_supervisor_node.py" name="cartographer_supervisor" output="screen">
    <param name="runtime_ns" value="$(arg runtime_ns)"/>
    <param name="config_root" value="$(arg config_root)"/>
    <param name="landmark_param_yaml" value="$(arg landmark_param_yaml)"/>
    <param name="mode" value="localization"/>
    <param name="map_name" value="$(arg map_name)"/>
    <param name="pbstream_path" value="$(arg pbstream_path)"/>
    <param name="map_topic" value="$(arg map_topic)"/>
    <param name="resolution" value="$(arg resolution)"/>
    <param name="publish_period_sec" value="$(arg publish_period_sec)"/>
    <param name="auto_start" value="$(arg auto_start)"/>
    <param name="cartographer_node_bin" value="$(arg cartographer_node_bin)"/>
    <param name="occupancy_grid_node_bin" value="$(arg occupancy_grid_node_bin)"/>
    <param name="include_unfrozen_submaps" value="false"/>
  </node>
</launch>
