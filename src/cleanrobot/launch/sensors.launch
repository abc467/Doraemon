<launch>
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera"            value="cam_1"/>
    <arg name="serial_no"         value="151222070155"/>
    <arg name="filters" value="disparity,spatial,temporal,decimation"/>
    <arg name="enable_pointcloud" value="true"/>
    
    <arg name="enable_color"      value="true"/>
    <arg name="enable_depth"      value="true"/>
    
    <arg name="depth_fps"         value="15"/>
    <arg name="color_fps"         value="15"/>
    <arg name="infra_fps"         value="15"/>

    <arg name="depth_width"       value="640"/>
    <arg name="depth_height"      value="480"/>
    <arg name="color_width"       value="640"/>
    <arg name="color_height"      value="480"/>

    <arg name="enable_sync"       value="true"/>

    <arg name="tf_prefix"         value="cam_1"/>
  </include>

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera"            value="cam_2"/>
    <arg name="serial_no"         value="151222070270"/>
    <arg name="filters" value="disparity,spatial,temporal,decimation"/>
    <arg name="enable_pointcloud" value="true"/>
    
    <arg name="enable_color"      value="true"/>
    <arg name="enable_depth"      value="true"/>
    
    <arg name="depth_fps"         value="15"/>
    <arg name="color_fps"         value="15"/>
    <arg name="infra_fps"         value="15"/>
    
    <arg name="depth_width"       value="640"/>
    <arg name="depth_height"      value="480"/>
    <arg name="color_width"       value="640"/>
    <arg name="color_height"      value="480"/>
    
    <arg name="enable_sync"       value="true"/>

    <arg name="tf_prefix"         value="cam_2"/>
  </include>

  <!-- <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera"            value="cam_3"/>
    <arg name="serial_no"         value="151222077433"/>
    <arg name="filters" value="disparity,spatial,temporal,decimation"/>
    <arg name="enable_pointcloud" value="true"/>
    
    <arg name="enable_color"      value="true"/>
    <arg name="enable_depth"      value="true"/>
    
    <arg name="depth_fps"         value="15"/>
    <arg name="color_fps"         value="15"/>
    <arg name="infra_fps"         value="15"/>
    
    <arg name="depth_width"       value="640"/>
    <arg name="depth_height"      value="480"/>
    <arg name="color_width"       value="640"/>
    <arg name="color_height"      value="480"/>
    
    <arg name="enable_sync"       value="true"/>

    <arg name="tf_prefix"         value="cam_3"/>
  </include> -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="urdf2cam1" 
        args="0 0 0 0 0 1.57 left_camera cam_1_link" />

  <node pkg="tf2_ros" type="static_transform_publisher" name="urdf2cam2" 
        args="0 0 0 0 0 1.57 right_camera cam_2_link" />

  <node pkg="tf2_ros" type="static_transform_publisher" name="urdf2cam3" 
        args="0.30007 0 0.74847 0 0.51487 0 base_link  cam_3_link " />
</launch>