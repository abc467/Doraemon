<launch>
  <!-- 这个 launch 只负责“原始轮速里程计 + 单 EKF”。
       IMU 零漂修正与协方差覆盖由 imu_bias_correction.launch 独立负责。 -->
  <!-- 是否启用 EKF 融合链路。关闭后只保留原始轮速里程计节点。 -->
  <arg name="enable_ekf" default="true"/>
  <!-- 工厂默认走生产态：关闭诊断 CSV，仅在排障时显式开启 debug_mode:=true。 -->
  <arg name="debug_mode" default="false"/>

  <!-- 轮速里程计串口输入。当前协议固定为 43 4C + 40 01 数据帧。
       payload = [last_wheel_update_ms, left_encoder_count, right_encoder_count,
                  left_speed, right_speed, seq, status]
       status 位定义：
       bit0 左轮数据有效，bit1 右轮数据有效
       bit2 左轮数据超时 >50 ms，bit3 右轮数据超时 >50 ms
       bit4 左右轮采样时间偏差 >15 ms -->
  <arg name="serial_device" default="/dev/odom"/>
  <arg name="serial_baudrate" default="115200"/>

  <!-- 原始里程计和 EKF 输出话题。
       调试态下会额外输出 balanced/aggressive 两套 EKF 对比话题。 -->
  <arg name="raw_odom_topic" default="/odom_raw"/>
  <arg name="ekf_topic" default="/odom"/>
  <arg name="ekf_balanced_topic" default="/odom_ekf_balanced"/>
  <arg name="ekf_aggressive_topic" default="/odom_ekf_aggressive"/>
  <arg name="imu_topic" default="/imu"/>
  <arg name="corrected_imu_topic" default="/imu_corrected"/>

  <!-- 时间同步参数：
       1. use_device_timestamp=true 时，使用协议里的 stamp_ms 映射到 ROS 时间
       2. false 时，直接使用主机收到串口帧的时间 -->
  <arg name="use_device_timestamp" default="true"/>
  <arg name="stamp_unit_to_sec" default="0.001"/>
  <arg name="stamp_resync_threshold_sec" default="0.5"/>

  <!-- 原始里程计的坐标系和 TF 发布控制。 -->
  <arg name="publish_raw_odom_tf" default="true"/>
  <arg name="frame_id" default="odom"/>
  <arg name="child_frame_id" default="base_footprint"/>

  <!-- 角速度方向修正。若底盘转向正负与 ROS 约定相反，可调整该符号。 -->
  <arg name="angular_velocity_sign" default="-1.0"/>

  <!-- 编码器积分参数：
       1. encoder_distance_per_count > 0 时，直接使用该值作为“每个编码值对应的米数”
       2. encoder_distance_per_count = 0 时，按下面公式自动计算
       距离系数 = pi * wheel_diameter / (gear_ratio * encoder_pulses_per_motor_revolution)
       3. left_wheel_scale / right_wheel_scale 用于单独微调左右轮比例 -->
  <arg name="encoder_distance_per_count" default="0.0"/>
  <arg name="left_wheel_scale" default="0.9995"/>
  <arg name="right_wheel_scale" default="1.0010"/>
  <arg name="wheel_diameter" default="0.165"/>
  <arg name="gear_ratio" default="9.0"/>
  <arg name="encoder_pulses_per_motor_revolution" default="10000.0"/>
  <arg name="wheel_separation" default="0.7307"/>

  <!-- 运动保护参数：
       用于限制异常的线速度、角速度、线加速度、角加速度。 -->
  <arg name="max_abs_linear_speed" default="2.0"/>
  <arg name="max_abs_angular_speed" default="1.5"/>
  <arg name="max_abs_linear_accel" default="3.0"/>
  <arg name="max_abs_angular_accel" default="6.0"/>
  <arg name="motion_guard_mode" default="reject"/>

  <!-- 原始轮速里程计节点：
       当前只按编码器累计值积分里程，协议中的 left_speed/right_speed 不参与积分。 -->
  <node pkg="wheel_speed_odom_bridge" type="wheel_speed_odom_node"
        name="wheel_speed_odom" output="screen">
    <param name="serial_device" value="$(arg serial_device)"/>
    <param name="serial_baudrate" value="$(arg serial_baudrate)"/>

    <!-- 原始 Odometry 消息的输出配置。 -->
    <param name="publish_topic" value="$(arg raw_odom_topic)"/>
    <param name="frame_id" value="$(arg frame_id)"/>
    <param name="child_frame_id" value="$(arg child_frame_id)"/>
    <param name="publish_odom_tf"
           value="$(eval (str(arg('publish_raw_odom_tf')).lower() == 'true') and (arg('raw_odom_topic') == '/odom' or arg('raw_odom_topic') == 'odom'))"/>

    <!-- 调试订阅 IMU，仅用于记录 imu 角速度到 CSV。 -->
    <param name="enable_imu_diagnostic" value="$(arg debug_mode)"/>
    <param name="imu_topic" value="$(arg imu_topic)"/>

    <!-- 协议时间戳同步配置。 -->
    <param name="use_device_timestamp" value="$(arg use_device_timestamp)"/>
    <param name="stamp_unit_to_sec" value="$(arg stamp_unit_to_sec)"/>
    <param name="stamp_resync_threshold_sec" value="$(arg stamp_resync_threshold_sec)"/>

    <!-- 编码器积分与底盘几何参数。 -->
    <param name="angular_velocity_sign" value="$(arg angular_velocity_sign)"/>
    <param name="encoder_distance_per_count" value="$(arg encoder_distance_per_count)"/>
    <param name="left_wheel_scale" value="$(arg left_wheel_scale)"/>
    <param name="right_wheel_scale" value="$(arg right_wheel_scale)"/>
    <param name="wheel_diameter" value="$(arg wheel_diameter)"/>
    <param name="gear_ratio" value="$(arg gear_ratio)"/>
    <param name="encoder_pulses_per_motor_revolution" value="$(arg encoder_pulses_per_motor_revolution)"/>
    <param name="wheel_separation" value="$(arg wheel_separation)"/>

    <!-- 运动保护参数。 -->
    <param name="max_abs_linear_speed" value="$(arg max_abs_linear_speed)"/>
    <param name="max_abs_angular_speed" value="$(arg max_abs_angular_speed)"/>
    <param name="max_abs_linear_accel" value="$(arg max_abs_linear_accel)"/>
    <param name="max_abs_angular_accel" value="$(arg max_abs_angular_accel)"/>
    <param name="motion_guard_mode" value="$(arg motion_guard_mode)"/>

    <!-- 合法时间间隔范围：
         若相邻两帧的 dt 超出该区间，会触发时间基重同步并跳过当前积分。 -->
    <param name="min_valid_odom_dt_sec" value="0.005"/>
    <param name="max_valid_odom_dt_sec" value="0.06"/>

    <!-- 原始里程计协方差。 -->
    <rosparam param="odom_pose_covariance_diagonal">[0.05, 0.05, 1000000.0, 1000000.0, 1000000.0, 0.1]</rosparam>
    <rosparam param="odom_twist_covariance_diagonal">[0.02, 1000000.0, 1000000.0, 1000000.0, 1000000.0, 0.05]</rosparam>

    <!-- 调试模式下写 wheel_speed_odom_debug.csv。 -->
    <param name="enable_diagnostic_log" value="$(arg debug_mode)"/>
  </node>

  <!-- EKF 融合链路：
       wheel_speed_odom.launch 不再启动 IMU 修正节点，这里直接消费外部提供的 corrected_imu_topic。
       调试态会额外拉起 balanced/aggressive 两套 EKF，仅输出对比 odom 话题，不发布 TF。 -->
  <group if="$(arg enable_ekf)">
    <node pkg="robot_localization" type="ekf_localization_node"
          name="wheel_speed_odom_ekf"
          output="screen" clear_params="true">
      <rosparam command="load" file="$(find wheel_speed_odom_bridge)/config/ekf_2d.yaml"/>
      <param name="odom0" value="$(arg raw_odom_topic)"/>
      <param name="imu0" value="$(arg corrected_imu_topic)"/>
      <param name="print_diagnostics" value="$(arg debug_mode)"/>
      <param name="publish_tf"
             value="$(eval arg('ekf_topic') == '/odom' or arg('ekf_topic') == 'odom')"/>
      <remap from="odometry/filtered" to="$(arg ekf_topic)"/>
    </node>

    <node pkg="robot_localization" type="ekf_localization_node"
          name="wheel_speed_odom_ekf_balanced"
          if="$(arg debug_mode)"
          output="screen" clear_params="true">
      <rosparam command="load" file="$(find wheel_speed_odom_bridge)/config/ekf_2d_balanced.yaml"/>
      <param name="odom0" value="$(arg raw_odom_topic)"/>
      <param name="imu0" value="$(arg corrected_imu_topic)"/>
      <param name="print_diagnostics" value="$(arg debug_mode)"/>
      <param name="publish_tf" value="false"/>
      <remap from="odometry/filtered" to="$(arg ekf_balanced_topic)"/>
    </node>

    <node pkg="robot_localization" type="ekf_localization_node"
          name="wheel_speed_odom_ekf_aggressive"
          if="$(arg debug_mode)"
          output="screen" clear_params="true">
      <rosparam command="load" file="$(find wheel_speed_odom_bridge)/config/ekf_2d_aggressive.yaml"/>
      <param name="odom0" value="$(arg raw_odom_topic)"/>
      <param name="imu0" value="$(arg corrected_imu_topic)"/>
      <param name="print_diagnostics" value="$(arg debug_mode)"/>
      <param name="publish_tf" value="false"/>
      <remap from="odometry/filtered" to="$(arg ekf_aggressive_topic)"/>
    </node>
  </group>
</launch>
