# 请求部分
string action      # 操作类型: "add", "delete", "update", "query"
int32 id           # 用户ID（删除/更新/查询时使用）
string name        # 用户名（用于添加）
int32 age          # 用户年龄（用于添加）
string email       # 用户邮箱（用于添加）

---
# 响应部分
string status      # 状态（"success" 或 "error"）
string message     # 详细信息
User[] users       # 返回的用户列表（可能是多个）