# Copy to /etc/doraemon/runtime.env on a Wheeltec senior_diff chassis.
DORAEMON_CHASSIS_DRIVER=wheeltec_senior_diff
CHASSIS_DRIVER=wheeltec_senior_diff

# Boot readiness waits for this controller device instead of legacy /dev/odom.
# /dev/wheeltec_controller is also supported when the optional udev rule is installed.
DORAEMON_CHASSIS_DEVICE=/dev/serial/by-id/usb-WCH.CN_USB_Single_Serial_0002-if00
WHEELTEC_SERIAL_DEVICE=/dev/serial/by-id/usb-WCH.CN_USB_Single_Serial_0002-if00

# Keep LiDAR/network checks enabled unless the deployment explicitly changes them.
DORAEMON_REQUIRE_LIDAR_PING=true

# This chassis has no depth cameras. Keep Orbbec and depth obstacle tracking off.
RUNTIME_START_DEPTH_CAMERAS=false
RUNTIME_ENABLE_DEPTH_OBSTACLE_TRACKING=false

# The Wheeltec driver does not publish wheel joint angles. Publish zero wheel
# joint states so RViz can render left/right/rear wheel links without TF gaps.
RUNTIME_START_JOINT_STATE_PUBLISHER=true

# Try to reload and localize the active map on boot. With
# ALLOW_NO_ACTIVE_MAP_STARTUP=1 in the systemd unit, a brand-new robot with no
# active map still boots service-ready instead of blocking startup.
STARTUP_RELOCALIZE_ENABLE=true
